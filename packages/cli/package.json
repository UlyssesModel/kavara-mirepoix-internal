{
  "name": "@mirepoix/cli",
  "version": "0.1.0",
  "description": "Mirepoix command-line entry. Wires @mirepoix/{core,coding}. Per ADR-001.",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": { ".": "./src/index.ts" },
  "bin": {
    "mirepoix": "./src/index.ts"
  },
  "dependencies": {
    "@mirepoix/coding": "workspace:*",
    "@mirepoix/core": "workspace:*"
  }
}
